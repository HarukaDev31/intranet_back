APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Stack: laravel_info (archivo) + slack (errores) si hay webhook. Sin webhook, solo archivo.
# LOG_STACK_CHANNELS=laravel_info,slack
LOG_STACK_CHANNELS=
LOG_FILE_LEVEL=info
LOG_SLACK_WEBHOOK_URL=
LOG_SLACK_USERNAME="Intranet Probusiness"
LOG_SLACK_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=probusiness_intranetv2_back
DB_USERNAME=root
DB_PASSWORD=

# Local WSL + MySQL/XAMPP en Windows (conexión mysql_local → localhost en middleware)
# IP del host Windows desde WSL: ip route show default | awk '{print $3}'
DB_HOST_LOCAL_WSL=172.31.144.1
DB_HOST_LOCAL=127.0.0.1
DB_DATABASE_LOCAL=db_probusiness_local
DB_USERNAME_LOCAL=root
DB_PASSWORD_LOCAL=
# Dominio BD para jobs en cola sin HTTP (Horizon/queue:work)
QUEUE_JOB_DB_DOMAIN=localhost
# Cola Horizon para jobs pesados de carga consolidada (Excel Drive, cortes). Debe tener supervisor en horizon.php.
CARGA_CONSOLIDADA_QUEUE=carga_consolidada

# Excel seguimiento Drive — hora de corte para bloques históricos CONTACTAR (HH:MM, America/Lima)
# Preferir edición en UI (tab Prospectos) o filas en system_configs:
# excel_seguimiento_hora_corte, excel_seguimiento_timezone
SEGUIMIENTO_CORTE_HORA=20:00
SEGUIMIENTO_CORTE_TIMEZONE=America/Lima

BROADCAST_DRIVER=log
CACHE_DRIVER=file
# Soporte TI: TTL de cache (usa CACHE_DRIVER: file, redis, etc.)
SOPORTE_TI_CACHE_TTL_LIST=120
SOPORTE_TI_CACHE_TTL_SHOW=180
SOPORTE_TI_CACHE_TTL_MENSAJES=60
SOPORTE_TI_CACHE_TTL_CATALOG=3600
FILESYSTEM_DRIVER=local
# Disco para nuevas subidas: local | public | s3
FILESYSTEM_UPLOAD_DISK=s3
FILESYSTEM_LEGACY_DISK=local
FILESYSTEM_LEGACY_PUBLIC_DISK=public
AWS_SIGNED_URL_MINUTES=120
AWS_SERVE_VIA_SIGNED_REDIRECT=true
# Vacío = objetos en la raíz del bucket (entregas/..., cargaconsolidada/...).
# La CDN (OBJECT_STORAGE_CDN_INCLUDE_PREFIX=false) apunta a esas rutas sin prefijo.
AWS_UPLOAD_PREFIX=
AWS_URL=
OBJECT_STORAGE_CDN_URL=https://cdn.probusiness.pe
OBJECT_STORAGE_CDN_INCLUDE_PREFIX=false
OBJECT_STORAGE_CDN_WHEN_S3=true
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Laravel Telescope (panel /telescope — requiere TELESCOPE_ENABLED=true)
TELESCOPE_ENABLED=false
TELESCOPE_PATH=telescope
# Producción sin login web: acceso con ?token=... (mismo valor que TELESCOPE_DASHBOARD_TOKEN)
TELESCOPE_DASHBOARD_TOKEN=
# Opcional: IPs permitidas separadas por coma
TELESCOPE_ALLOWED_IPS=
TELESCOPE_ALLOWED_EMAILS=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6380

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"
# Si MAIL_LOCAL_REDIRECT_TO está definido: redirige en local, localhost o conexión mysql_local (MailTrait)
MAIL_LOCAL_REDIRECT_TO=
# Destino del correo de solicitud de documentos (pedir_documentos)
COORDINATION_EMAIL=
COORDINATION_EMAIL_2=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Lead formulario landing consolidado (Bearer). Mismo valor que PUBLIC_LANDING_CONSOLIDADO_FORM_TOKEN en el front Astro.
LANDING_CONSOLIDADO_FORM_TOKEN=

# Lead formulario landing curso (Bearer). Mismo valor que PUBLIC_LANDING_CURSO_FORM_TOKEN en el front Astro.
LANDING_CURSO_FORM_TOKEN=

# Token estático de solo lectura para integraciones externas (Bearer).
THIRD_PARTY_READ_ONLY_TOKEN=

# Límite de peticiones por minuto (por IP) al endpoint JSON público de cotizaciones.
THIRD_PARTY_COTIZACION_EXPORT_RATE_LIMIT=30

# Bitrix24 webhook (REST entrante). Vacío = no se encolan jobs CRM.
# BITRIX_WEBHOOK_URL=https://tuportal.bitrix24.com/rest/1/codigo/
BITRIX_WEBHOOK_URL=
BITRIX_HTTP_TIMEOUT=30
BITRIX_QUEUE=default
# Webhook para imopenlines.session.intercept (paso 3 Meta + Bitrix)
BITRIX_WEBHOOK_INTERCEPT=

# =============================================================================
# NUEVAS — Meta WhatsApp coordinación + Bitrix línea 39 (fromNumber consolidado)
# Docs: docs/META_WHATSAPP_API.md
# =============================================================================
META_WHATSAPP_COORDINACION_ENABLED=false
META_WHATSAPP_LEGACY_FALLBACK=true
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_APP_SECRET=
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=pb_inbox_webhook_2026
META_WHATSAPP_WABA_ID=
META_WHATSAPP_PHONE_NUMBER_ID=1062249786981832
META_WHATSAPP_INBOX_DISPLAY_NUMBER=
META_WHATSAPP_INBOX_QUEUE=notificaciones
# Dominio BD para jobs WaInbox en cola (local/WSL: localhost)
META_WHATSAPP_INBOX_JOB_DOMAIN=localhost
# false si websockets/Pusher no está levantado (no bloquea envío Meta)
META_WHATSAPP_INBOX_BROADCAST=true
META_WHATSAPP_GRAPH_VERSION=v19.0
WA_INBOX_ALERT_PHONE=
COPILOTO_EVOLUTION_WEBHOOK_ENABLED=false
META_WHATSAPP_LANGUAGE=es_PE
META_WHATSAPP_QUEUE=notificaciones
META_WHATSAPP_EMPTY_PARAM_PLACEHOLDER=—
META_WHATSAPP_FALLBACK_PUBLIC_URL=true

# WhatsApp Copiloto — Ventas (Meta API, separado del inbox coordinación)
# Webhook dedicado: POST /api/webhooks/meta/whatsapp-copiloto
# También enruta desde /api/webhooks/meta/whatsapp-inbox si phone_number_id coincide
META_WHATSAPP_COPILOTO_ENABLED=false
META_WHATSAPP_COPILOTO_PHONE_NUMBER_ID=
# Opcional: solo si Copiloto usa un token distinto a META_WHATSAPP_ACCESS_TOKEN (inbox)
# META_WHATSAPP_COPILOTO_ACCESS_TOKEN=
META_WHATSAPP_COPILOTO_APP_SECRET=
META_WHATSAPP_COPILOTO_WEBHOOK_VERIFY_TOKEN=
META_WHATSAPP_COPILOTO_WABA_ID=
META_WHATSAPP_COPILOTO_GRAPH_VERSION=v19.0
META_WHATSAPP_COPILOTO_DISPLAY_NUMBER=
META_WHATSAPP_COPILOTO_SESSION_SLUG=ventas
META_WHATSAPP_COPILOTO_QUEUE=notificaciones
META_WHATSAPP_COPILOTO_BROADCAST=true
META_WHATSAPP_COPILOTO_JOB_DOMAIN=
META_WHATSAPP_COPILOTO_ANALYSIS_ENABLED=true
META_WHATSAPP_COPILOTO_ANALYSIS_ALLOWED_PHONES=51912705923
# =============================================================================
# NUEVAS — Object storage S3 + CDN (subidas y URLs Meta)
# Docs: docs/S3_MIGRACION.md
# =============================================================================
# FILESYSTEM_UPLOAD_DISK=s3          (ya definido arriba)
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_BUCKET / AWS_DEFAULT_REGION
# AWS_UPLOAD_PREFIX=probusiness      (prefijo en disco s3; plantillas bare: templates/)
# AWS_SIGNED_URL_MINUTES=120
# AWS_SERVE_VIA_SIGNED_REDIRECT=true
# OBJECT_STORAGE_CDN_URL=https://cdn.probusiness.pe
# OBJECT_STORAGE_CDN_INCLUDE_PREFIX=false
# OBJECT_STORAGE_CDN_WHEN_S3=true

# =============================================================================
# NUEVAS — Google Drive Excel confirmación (OAuth usuario)
# Docs: docs/GOOGLE_DRIVE_EXCEL_OAUTH.md
# =============================================================================
# GOOGLE_SERVICE_ENABLED=true
# GOOGLE_DRIVE_EXCEL_AUTH_MODE=oauth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_DRIVE_EXCEL_CONFIRMACION_ROOT_FOLDER_ID=
# GOOGLE_DRIVE_OAUTH_REDIRECT_URI=http://localhost:8001/api/google/drive/oauth/callback
# GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=
# GOOGLE_DRIVE_OAUTH_TOKEN_FILE=google-drive-oauth-token.json
# GOOGLE_DRIVE_EXCEL_CONFIRMACION_SHARED_DRIVE_ID=
# (Shared drive solo con GOOGLE_DRIVE_EXCEL_AUTH_MODE=service_account en Workspace)

# Carpeta raíz Drive para Excel de seguimiento consolidado (cotizaciones por consolidado)
# EXCEL_SEGUIMIENTO_CONSOLIDADO_ID=

# Opcional: stage/categoría del negocio consolidado (por defecto ver config/landing_consolidado.php).
# BITRIX_CONSOLIDADO_DEAL_STAGE_ID=UC_NF1ZJG

# Curso Bitrix: si no defines la variable, sync activo con webhook. false = no encolar curso.
# LANDING_CURSO_BITRIX_ENABLED=false

# Embudo curso (ej. categoría 9 = Curso de Importación). Ver config/landing_curso.php.
# BITRIX_CURSO_DEAL_CATEGORY_ID=9
# BITRIX_CURSO_DEAL_STAGE_ID=C9:UC_33L0M2
# BITRIX_CURSO_UF_FECHA_REGISTRO=UF_CRM_1718205777413
# BITRIX_CURSO_UF_SERVICIOS=UF_CRM_1732648597921
# BITRIX_CURSO_UF_SERVICIOS_VALUE=173
# BITRIX_CURSO_UF_PAUTA=UF_CRM_1716916721532

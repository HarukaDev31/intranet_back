# Overlay PROD (NO se commitea: ver .gitignore → docker-compose.prod.yml)
#
# En el servidor PROD:
#   cp docker-compose.prod.yml.example docker-compose.prod.yml
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# .env típico PROD:
#   APP_PORT=8082
#   COMPOSE_PROJECT_NAME=intranet_back
#   APP_ENV=production
#   APP_DEBUG=false
#   DB_HOST=localhost
#   DB_SOCKET=/var/run/mysqld/mysqld.sock
#   DOCKER_REDIS_HOST=redis
#   FORWARD_REDIS_PORT=6381
#   REDIS_PREFIX=intranet_back_
#   LARAVEL_WEBSOCKETS_PORT=6001
#   HORIZON_PREFIX=intranet_horizon:

name: intranet_back

services:
  redis:
    ports:
      - "127.0.0.1:${FORWARD_REDIS_PORT:-6381}:6379"

  app:
    volumes:
      - ${MYSQL_SOCKET_HOST:-/var/run/mysqld/mysqld.sock}:/var/run/mysqld/mysqld.sock

  horizon:
    volumes:
      - ${MYSQL_SOCKET_HOST:-/var/run/mysqld/mysqld.sock}:/var/run/mysqld/mysqld.sock

  scheduler:
    volumes:
      - ${MYSQL_SOCKET_HOST:-/var/run/mysqld/mysqld.sock}:/var/run/mysqld/mysqld.sock
